{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flowforge: Build extension and webview",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "problemMatcher": []
    },
    {
      "label": "Flowforge: Watch extension and webview",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "flowforge",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[ext\\] \\[esbuild\\] watching\\.\\.\\.",
          "endsPattern": "\\[web\\].*Local:\\s+http://localhost:5173/"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
